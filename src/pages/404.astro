---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Julius Bruch Digital Solutions">
    <main>
        <section class="legal-content" style="text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh;">
            <div class="container">
                <h1 style="font-size: 5rem; margin-bottom: 0; color: var(--accent-primary);">404</h1>
                <h2 data-en="Page Not Found" data-de="Seite nicht gefunden" style="margin-top: 0; border: none;">
                    Page Not Found
                </h2>
                <p data-en="Sorry, the page you are looking for does not exist or has been moved." data-de="Entschuldigung, die von Ihnen gesuchte Seite existiert nicht oder wurde verschoben.">
                    Sorry, the page you are looking for does not exist or has been moved.
                </p>
                <div style="margin-top: 2rem;">
                    <a href="/" class="cta-button">
                        <i class="fas fa-home"></i> <span data-en="Back to Home" data-de="Zurück zur Startseite">Back to Home</span>
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>