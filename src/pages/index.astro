---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import profileImg from '../assets/images/profile-image.png';
import heroVideoUrl from '../assets/hero-video.mp4';

const faqs = [
    {
        questionEn: "What is your current availability?",
        questionDe: "Wie ist Ihre aktuelle Verfügbarkeit?",
        answerEn: "During the semester, my freelance capacity is limited. However, during the semester break (June 13, 2026 to September 30, 2026), I am available for 20 hours per week. The exact schedule can be arranged flexibly.",
        answerDe: "Während des Semesters ist meine freiberufliche Kapazität begrenzt. In der vorlesungsfreien Zeit (13.06.2026 bis 30.09.2026) stehe ich jedoch mit einer Arbeitszeit von 20 Stunden pro Woche zur Verfügung. Die genaue Einteilung kann flexibel vereinbart werden."
    },
    {
        questionEn: "How long does a typical project take?",
        questionDe: "Wie lange dauert ein typisches Projekt?",
        answerEn: "Depending on the complexity, a typical project can take anywhere from a few days for simple automated workflows to several weeks for comprehensive, multi-screen business applications.",
        answerDe: "Je nach Komplexität kann ein typisches Projekt von wenigen Tagen für einfache automatisierte Workflows bis hin zu mehreren Wochen für umfassende Geschäftsanwendungen mit mehreren Bildschirmen dauern."
    },
    {
        questionEn: "Do I need special licenses?",
        questionDe: "Benötige ich spezielle Lizenzen?",
        answerEn: "If you use standard Microsoft 365 connectors (like SharePoint and Outlook), usage is typically included in your existing plan. Premium connectors (like SQL Server or Salesforce) require standalone Power Apps licenses.",
        answerDe: "Wenn Sie Standard-Konnektoren von Microsoft 365 (wie SharePoint und Outlook) verwenden, ist die Nutzung normalerweise in Ihrem bestehenden Plan enthalten. Premium-Konnektoren (wie SQL Server oder Salesforce) erfordern eigenständige Power Apps-Lizenzen."
    },
    {
        questionEn: "Do you offer post-project support?",
        questionDe: "Bieten Sie Unterstützung nach Projektabschluss an?",
        answerEn: "Yes! I provide ongoing maintenance, troubleshooting, and feature additions to ensure your solution continues to run smoothly and adapts to your evolving business needs.",
        answerDe: "Ja! Ich biete fortlaufende Wartung, Fehlerbehebung und das Hinzufügen von Funktionen an, um sicherzustellen, dass Ihre Lösung weiterhin reibungslos läuft und sich an Ihre sich entwickelnden Geschäftsanforderungen anpasst."
    },
    {
        questionEn: "What is needed to start a project?",
        questionDe: "Was wird benötigt, um zu starten?",
        answerEn: "To build and deploy solutions for your organization, I typically need a guest account or a dedicated developer account in your Microsoft 365 tenant. Depending on the project, appropriate licenses (e.g., Power Apps Premium) and permissions to access required data sources or create environments may also be necessary.",
        answerDe: "Um Lösungen für Ihr Unternehmen zu entwickeln und bereitzustellen, benötige ich in der Regel einen Gastzugang oder ein dediziertes Entwicklerkonto in Ihrem Microsoft 365 Tenant. Je nach Projekt werden zudem entsprechende Lizenzen (z. B. Power Apps Premium) sowie Berechtigungen benötigt, um auf erforderliche Datenquellen zuzugreifen oder Umgebungen (Environments) zu erstellen."
    },
    {
        questionEn: "Do I need a service account?",
        questionDe: "Wird ein Dienstkonto (Service Account) benötigt?",
        answerEn: "Yes, a dedicated service account is highly recommended. It acts as a neutral account for running automated workflows and sending system emails, ensuring that processes remain independent of individual user accounts.",
        answerDe: "Ja, ein dediziertes Dienstkonto (Service Account) wird dringend empfohlen. Es fungiert als neutrales Konto für die Ausführung von automatisierten Workflows und den Versand von System-E-Mails, wodurch sichergestellt wird, dass die Prozesse unabhängig von einzelnen Benutzerkonten bleiben."
    },
    {
        questionEn: "What project costs should I expect?",
        questionDe: "Mit welchen Projektkosten muss ich rechnen?",
        answerEn: "Every project is unique. Smaller automations and adjustments start at around €500, while comprehensive Canvas Apps begin at approximately €2,500. Feel free to contact me for a custom fixed-price quote.",
        answerDe: "Jedes Projekt ist individuell. Kleinere Automatisierungen und Anpassungen starten bei ca. 500€, während umfangreiche Canvas Apps bei ca. 2.500€ beginnen. Kontaktieren Sie mich gerne für ein individuelles Festpreisangebot."
    }
];

// JSON-LD Schema for a Freelance Developer (Person Entity)
const schemaData = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Julius Bruch",
    "jobTitle": "Freelance Power Apps Developer",
    "url": Astro.site ? Astro.site.toString() : "https://jb-solutions.digital",
    "sameAs": [
        "https://www.linkedin.com/in/julius-bruch-054296294",
        "https://www.freelance.de/freelancer/317578-Power-Apps-Maker-Power-Automate-Sharepoint"
    ],
    "description": "Freelance Power Apps developer and Microsoft 365 specialist based in Leipzig, Germany.",
    "address": {
        "@type": "PostalAddress",
        "addressLocality": "Leipzig",
        "addressCountry": "DE"
    }
};
---

<Layout 
    title="Julius Bruch | Freelance Power Apps & Microsoft 365 Developer"
    description="Streamline your workflows with tailored Microsoft 365 solutions. Freelance developer specializing in Power Apps, Power Automate, and SharePoint based in Leipzig."
>
    <!-- Inject Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <main>
    <!-- Hero Section -->
    <section id="home" class="hero">
    <video autoplay muted playsinline class="hero-video">
        <source src={heroVideoUrl} type="video/mp4">
        Your browser does not support the video tag.
    </video>
        <div class="container">
            <h1 data-en="Digitalize Your Business Processes" data-de="Digitalisieren Sie Ihre Geschäftsprozesse">Digitalize Your Business Processes</h1>
            <p data-en="Tailored Microsoft 365 solutions specializing in Power Apps, Automate, and SharePoint." data-de="Maßgeschneiderte Microsoft 365-Lösungen mit Fokus auf Power Apps, Automate und SharePoint.">Tailored Microsoft 365 solutions specializing in Power Apps, Automate, and SharePoint.</p>
            <div class="hero-buttons">
                <a href="#about" class="cta-button" data-en="Learn More" data-de="Mehr erfahren">Learn More</a>
                <a href="#contact" class="cta-button secondary" data-en="To Contact Form" data-de="Zum Kontaktformular">To Contact Form</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2><i class="fas fa-user"></i> <span data-en="About Me" data-de="Über mich">About Me</span></h2>
            
            <div class="about-content">
                <div class="profile-pic">
                    <Image src={profileImg} alt="A professional headshot of Julius Bruch" />
                </div>

                <div class="about-text">
                    <p>
                        <span data-en="Master's student in Business Informatics at University of Leipzig. Freelance Power Apps developer and Microsoft 365 specialist. I build scalable, enterprise-grade solutions that streamline operations, automate workflows, and unlock the full potential of Microsoft 365." data-de="Masterstudent der Wirtschaftsinformatik an der Universität Leipzig. Freiberuflicher Power Apps-Entwickler und Microsoft 365-Spezialist. Ich entwickle skalierbare Lösungen, die Abläufe optimieren, Workflows automatisieren und das volle Potenzial von Microsoft 365 ausschöpfen.">Master's student in Business Informatics at University of Leipzig. Freelance Power Apps developer and Microsoft 365 specialist. I build scalable, enterprise-grade solutions that streamline operations, automate workflows, and unlock the full potential of Microsoft 365.</span>
                    </p>

                    <h3 class="certifications-title" data-en="Profiles" data-de="Profile">Profiles</h3>
                    <div class="certificates" style="margin-bottom: 2rem;">
                        <a href="https://www.linkedin.com/in/julius-bruch-054296294" target="_blank" rel="noopener" class="certificate-badge" title="View LinkedIn Profile">
                            <div class="cert-icon"><i class="fab fa-linkedin"></i></div>
                            <div class="cert-text">
                                <div class="cert-name">LinkedIn</div>
                                <div class="cert-title" data-en="Professional Network" data-de="Berufliches Netzwerk">Professional Network</div>
                            </div>
                            <i class="fas fa-external-link-alt cert-link-icon"></i>
                        </a>
                        <a href="https://www.freelance.de/freelancer/317578-Power-Apps-Maker-Power-Automate-Sharepoint" target="_blank" rel="noopener" class="certificate-badge" title="View Freelance.de Profile">
                            <div class="cert-icon"><i class="fas fa-briefcase"></i></div>
                            <div class="cert-text">
                                <div class="cert-name">Freelance.de</div>
                                <div class="cert-title" data-en="Freelancer Profile" data-de="Freelancer Profil">Freelancer Profile</div>
                            </div>
                            <i class="fas fa-external-link-alt cert-link-icon"></i>
                        </a>
                    </div>

                    <h3 class="certifications-title" data-en="Certifications" data-de="Zertifizierungen">Certifications</h3>
                    <div class="certificates">
                        <a href="https://learn.microsoft.com/api/credentials/share/de-de/JuliusBruch-8204/F40F5E7ACD4070C8?sharingId=7FF4BF1BE48218B6" target="_blank" rel="noopener" class="certificate-badge" title="View PL-200 Certification">
                            <div class="cert-icon">🏆</div>
                            <div class="cert-text">
                                <div class="cert-name">PL-200</div>
                                <div class="cert-title" data-en="Power Platform Functional" data-de="Power Platform Funktional">Power Platform Functional</div>
                            </div>
                            <i class="fas fa-external-link-alt cert-link-icon"></i>
                        </a>
                        <a href="https://learn.microsoft.com/api/credentials/share/de-de/JuliusBruch-8204/13FAF2A8030C8E7A?sharingId=7FF4BF1BE48218B6" target="_blank" rel="noopener" class="certificate-badge" title="View PL-900 Certification">
                            <div class="cert-icon">🏆</div>
                            <div class="cert-text">
                                <div class="cert-name">PL-900</div>
                                <div class="cert-title" data-en="Power Platform Fundamentals" data-de="Power Platform Grundlagen">Power Platform Fundamentals</div>
                            </div>
                            <i class="fas fa-external-link-alt cert-link-icon"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <h2><i class="fas fa-layer-group"></i> <span data-en="My Services" data-de="Meine Dienstleistungen">My Services</span></h2>
            <p class="section-subtitle" data-en="Select a service below for details and licensing info." data-de="Wählen Sie einen Service für Details und Lizenzinfos.">Select a service below for details and licensing info.</p>
            <div class="services-grid">
                <ServiceCard 
                    href="/service-1" 
                    title="View Power Apps Development details" 
                    icon="📱" 
                    titleEn="Power Apps Development" 
                    titleDe="Power Apps Entwicklung" 
                    descEn="Custom Canvas and Model-driven apps to digitize your processes." 
                    descDe="Maßgeschneiderte Power Apps zur Digitalisierung Ihrer Prozesse." 
                />
                <ServiceCard 
                    href="/service-2" 
                    title="View Power Automate Solutions details" 
                    icon="⚙️" 
                    titleEn="Power Automate Solutions" 
                    titleDe="Power Automate Lösungen" 
                    descEn="Workflow automation and process optimization to save time and reduce errors." 
                    descDe="Workflow-Automatisierung und Prozessoptimierung, um Zeit zu sparen und Fehler zu reduzieren." 
                />
                <ServiceCard 
                    href="/service-3" 
                    title="View SharePoint Services details" 
                    icon="📂" 
                    titleEn="SharePoint Services" 
                    titleDe="SharePoint Services" 
                    descEn="Configuration, site design, and governance for modern collaboration spaces and Power Apps." 
                    descDe="Konfiguration, Site-Design und Governance für moderne Zusammenarbeitsbereiche und Power Apps." 
                />
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects">
        <div class="container">
            <h2><i class="fas fa-laptop-code"></i> <span data-en="Projects" data-de="Projekte">Projects</span></h2>
            <p class="section-subtitle" data-en="Explore a selection of my recent work." data-de="Entdecken Sie eine Auswahl meiner aktuellen Arbeiten.">Explore a selection of my recent work.</p>
            <div class="projects-grid">
                <ProjectCard 
                    href="/project-1" 
                    title="View project details" 
                    icon="✈️" 
                    titleEn="Travel Expenses App" 
                    titleDe="Reisekosten App" 
                    descEn="Automated approval workflow with PDF generation for fast accounting." 
                    descDe="Automatisierter Genehmigungs-Workflow mit PDF-Berichterstellung für die Buchhaltung." 
                />
                <ProjectCard 
                    href="/project-3" 
                    title="View project details" 
                    icon="📋" 
                    titleEn="Project Management App" 
                    titleDe="Projektmanagement App" 
                    descEn="Central SharePoint dashboard for project tracking and team collaboration." 
                    descDe="Zentrales SharePoint-Dashboard für Projektverfolgung und Teamzusammenarbeit." 
                />
                <ProjectCard 
                    href="/project-2" 
                    title="View project details" 
                    icon="📅" 
                    titleEn="Calendar Export App" 
                    titleDe="Kalender Export App" 
                    descEn="Power App to filter and export Outlook calendar events via Graph API." 
                    descDe="Power App zum Filtern und Exportieren von Outlook-Kalenderterminen via Graph API." 
                />
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="faq">
        <div class="container">
            <h2><i class="fas fa-question-circle"></i> <span data-en="Frequently Asked Questions" data-de="Häufig gestellte Fragen">Frequently Asked Questions</span></h2>
            <div class="faq-list">
                {faqs.map((faq) => (
                    <div class="faq-item">
                        <button class="faq-question">
                            <span data-en={faq.questionEn} data-de={faq.questionDe}>{faq.questionEn}</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="faq-answer">
                            <div class="faq-answer-inner">
                                <p data-en={faq.answerEn} data-de={faq.answerDe}>{faq.answerEn}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2><i class="fas fa-envelope"></i> <span data-en="Contact Form" data-de="Kontaktformular">Contact Form</span></h2>
            
            <div id="form-success-message" class="success-message-card">
                <div class="success-icon" style="font-size: 3rem; color: var(--accent-primary); margin-bottom: 0.5rem;">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h3 data-en="Message sent successfully! A confirmation email has been sent to your inbox." data-de="Nachricht erfolgreich gesendet! Eine Bestätigungs-E-Mail wurde an Ihren Posteingang gesendet." style="color: var(--text-primary);">Message sent successfully!</h3>
            </div>
            <!-- Netlify Contact Form -->
            <form id="netlify-contact-form" class="contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/">
                <input type="hidden" name="form-name" value="contact" />
                <div style="display: none;" aria-hidden="true">
                    <label>Don’t fill this out if you're human: <input name="bot-field" tabindex="-1" /></label>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="name" data-en="Name" data-de="Name">Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email" data-en="Email" data-de="E-Mail">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="message" data-en="Message" data-de="Nachricht">Message</label>
            <textarea id="message" name="message" rows="4" required></textarea>
                </div>
                <div class="form-checkbox">
                    <input type="checkbox" id="send-confirmation" name="send-confirmation">
                    <label for="send-confirmation" style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; font-weight: normal;">
                        <span data-en="Send a copy of this message to my inbox" data-de="Eine Kopie der Nachricht an mein Postfach senden">Send a copy of this message to my inbox</span>
                    </label>
                </div>
                <div class="form-checkbox">
                    <input type="checkbox" id="privacy-consent" name="privacy-consent" required>
                    <label for="privacy-consent" style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; font-weight: normal;">
                        <span data-en="I have read and agree to the " data-de="Ich habe die ">I have read and agree to the </span><a href="/datenschutz" style="color: var(--text-primary); text-decoration: underline;" data-en="Data Privacy Policy" data-de="Datenschutzerklärung">Data Privacy Policy</a><span data-en="." data-de=" gelesen und stimme der Verarbeitung meiner Daten zu.">.</span><span style="color: #ff4b4b; font-weight: bold;" title="Required field"> *</span>
                    </label>
                </div>
                <button type="submit" class="cta-button">
                    <i class="fas fa-paper-plane"></i>
                    <span data-en="Send Message" data-de="Nachricht senden">Send Message</span>
                </button>
            </form>
        </div>
    </section>
  </main>
</Layout>