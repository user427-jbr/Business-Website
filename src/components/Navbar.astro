---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo.png';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const link = (hash: string) => isHome ? hash : `/${hash}`;
---

<!-- Navigation -->
<nav class="navbar">
    <div class="container">
        <div class="nav-wrapper">
            <a href="/" class="logo" title="Back to home">
                <Image src={logoImg} alt="Julius Bruch Logo" class="logo-image" />
                <div class="logo-content">
                    <div class="logo-name">Julius Bruch</div>
                    <div class="logo-tagline">Digital Solutions</div>
                </div>
            </a>
            
            <!-- Hamburger Menu -->
            <button class="hamburger" id="hamburger" title="Toggle menu" aria-label="Toggle navigation menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            
            <ul class="nav-menu" id="navMenu">
                <li><a href={link('#about')} class="nav-link" data-en="About" data-de="Über mich">About</a></li>
                <li><a href={link('#services')} class="nav-link" data-en="Services" data-de="Dienstleistungen">Services</a></li>
                <li><a href={link('#projects')} class="nav-link" data-en="Projects" data-de="Projekte">Projects</a></li>
                <li><a href={link('#faq')} class="nav-link" data-en="FAQ" data-de="FAQ">FAQ</a></li>
                <li><a href={link('#contact')} class="nav-link" data-en="Contact" data-de="Kontakt">Contact</a></li>
                <li class="nav-lang-item">
                    <button class="theme-toggle" id="themeToggleMobile" title="Toggle theme" aria-label="Toggle dark and light theme">
                        <i class="fas fa-moon"></i>
                    </button>
                    <button class="lang-toggle" id="langToggleMobile" title="Toggle language" aria-label="Toggle language between English and German">
                        <i class="fas fa-globe"></i>
                    </button>
                    <select class="lang-switch" id="langSwitchMobile" style="display: none;">
                        <option value="en">EN</option>
                        <option value="de">GER</option>
                    </select>
                </li>
            </ul>
            
            <div class="nav-controls">
                <button class="theme-toggle" id="themeToggle" title="Toggle theme" aria-label="Toggle dark and light theme">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="lang-toggle" id="langToggle" title="Toggle language" aria-label="Toggle language between English and German">
                    <i class="fas fa-globe"></i>
                </button>
                <select class="lang-switch" id="langSwitch" style="display: none;">
                    <option value="en">EN</option>
                    <option value="de">GER</option>
                </select>
            </div>
        </div>
    </div>
</nav>